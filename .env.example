# Copy to .env for local docker compose (never commit .env with real secrets).
# API/worker use hostname "mongo" inside Docker. GUI tools on your Mac use localhost:27017/tbs.
MONGO_URI=mongodb://mongo:27017/tbs
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-production
JWT_EXPIRY=168h
APP_URL=http://localhost
TICKET_SECRET=
SENDGRID_API_KEY=
EMAIL_FROM=
# First admin: API creates or promotes this user on startup (and cmd/seed) when both are set.
# Log in at /login with this email + password to access /admin.
ADMIN_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=changeme-dev-only
# Google OAuth 2.0 (issue #13) — create credentials in Google Cloud Console.
# Authorized redirect URI must match APP_URL + /api/auth/google/callback
# (local dev behind nginx): http://localhost/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
